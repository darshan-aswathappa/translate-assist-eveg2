# Copy to .env for local dev. These identify the Supabase backend project only —
# Groq / Anthropic API keys are entered in the app's Settings screen, never here.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Dev mode for UI iteration without glasses/backend ("true" to enable).
# VITE_DEV_MODE=true
