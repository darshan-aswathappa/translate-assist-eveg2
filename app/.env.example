# Copy to .env for local dev. These identify the Supabase backend project only —
# Deepgram / Anthropic API keys are entered in the app's Settings screen, never here.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Stripe Payment Links for the Pro tier ($7.99/mo, $72/yr).
VITE_CHECKOUT_URL_MONTHLY=https://buy.stripe.com/...
VITE_CHECKOUT_URL_YEARLY=https://buy.stripe.com/...

# Dev mode for UI iteration without glasses/backend ("true" to enable).
# VITE_DEV_MODE=true
